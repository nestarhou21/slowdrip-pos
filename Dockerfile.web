# Use Node 20 alpine as base
FROM node:20-alpine AS builder

WORKDIR /app

# Enable corepack for npm/yarn/pnpm (just in case, though we use npm)
RUN corepack enable

# Copy workspace config and install dependencies
COPY package-lock.json package.json turbo.json ./
COPY packages/store/package.json ./packages/store/
COPY packages/ui/package.json ./packages/ui/
COPY packages/config-tailwind/package.json ./packages/config-tailwind/
COPY packages/config-typescript/package.json ./packages/config-typescript/
COPY apps/web/package.json ./apps/web/
# (We don't need apps/admin here)

RUN npm install

# Copy source code
COPY packages ./packages
COPY apps/web ./apps/web

# Accept build arguments
ARG VITE_API_BASE_URL
ARG VITE_SUPABASE_URL
ARG VITE_SUPABASE_ANON_KEY

# Expose them as environment variables during the build
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL
ENV VITE_SUPABASE_URL=$VITE_SUPABASE_URL
ENV VITE_SUPABASE_ANON_KEY=$VITE_SUPABASE_ANON_KEY

# Build the web app
RUN npm run build --workspace=web

# Use a lightweight static server
FROM node:20-alpine AS runner
WORKDIR /app

# Install simple http server
RUN npm install -g serve

# Copy built assets from builder
COPY --from=builder /app/apps/web/dist ./dist

# Expose port (defaulting to 3000, but railway will map it via $PORT)
ENV PORT=3000
EXPOSE 3000

# Start server on 3000
CMD serve -s dist -l $PORT
